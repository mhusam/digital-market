NEXT_PUBLIC_API_URL=http://localhost:8080

# Server-side API URL for SSR / Docker (uncomment when running in Docker)
# API_INTERNAL_URL=http://api:8080

# Auth.js v5 — Google OAuth
# Generate AUTH_SECRET: openssl rand -base64 32
AUTH_SECRET=replace-with-a-random-32-char-secret
AUTH_GOOGLE_ID=your-google-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-google-client-secret

# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Authorized redirect URIs:
#   Dev:  http://localhost:3001/api/auth/callback/google
#   Prod: https://your-domain.com/api/auth/callback/google
