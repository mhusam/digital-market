# Copy to .env.docker and adjust:  cp .env.docker.example .env.docker
# Then:  docker compose --env-file .env.docker up --build

# --- Unique host ports (defaults match docker-compose.yml) ---
POSTGRES_HOST_PORT=25432
API_HOST_PORT=28080
UI_ADMIN_HOST_PORT=23000
UI_CUSTOMER_HOST_PORT=23001

# --- PostgreSQL (inside Docker network the API uses postgres:5432) ---
POSTGRES_DB=sell_online
POSTGRES_USER=sell_online
POSTGRES_PASSWORD=sell_online

# --- API ---
JWT_SECRET=replace-with-a-long-random-secret-at-least-256-bits-for-production
CORS_ALLOWED_ORIGINS=http://localhost:23000,http://localhost:23001

# ui-admin BFF uses API_URL (server-only, set in docker-compose.yml as http://api:8080 automatically)
# ui-customer browser-visible API URL (must match API_HOST_PORT when developing on host)
NEXT_PUBLIC_API_URL=http://localhost:28080
NEXT_PUBLIC_CUSTOMER_URL=http://localhost:23001

# PayPal redirect targets (customer app on Docker host port)
PAYPAL_RETURN_URL=http://localhost:23001/checkout/success
PAYPAL_CANCEL_URL=http://localhost:23001/checkout/cancelled

# Auth.js v5 — Google OAuth (ui-customer)
# Generate: openssl rand -base64 32
AUTH_SECRET=replace-with-a-random-32-char-secret
AUTH_GOOGLE_ID=your-google-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-google-client-secret
# Must match the ui-customer public URL (used for OAuth callback)
AUTH_URL=http://localhost:23001

# --- Optional: PayPal / S3 (leave blank for local UI-only testing) ---
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# PAYPAL_WEBHOOK_ID=
# S3_ENDPOINT=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
