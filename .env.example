# ============================================================
# Root-level .env.example — copy relevant sections to each app
# ============================================================

# --- apps/api ---
# Local Postgres (default). With Docker Compose use host port 25432 — see README "Docker".
DATABASE_URL=jdbc:postgresql://localhost:5432/sell_online
DATABASE_USERNAME=sell_online
DATABASE_PASSWORD=your_password

JWT_SECRET=change-me-to-a-secure-256-bit-random-string
JWT_EXPIRATION_MS=86400000

PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id
PAYPAL_MODE=sandbox  # change to 'live' for production
PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com

S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=sell-online-assets
S3_ACCESS_KEY=your_r2_access_key
S3_SECRET_KEY=your_r2_secret_key
S3_SIGNED_URL_TTL=60  # minutes

MAIL_HOST=smtp.resend.com
MAIL_PORT=587
MAIL_USERNAME=resend
MAIL_PASSWORD=your_resend_api_key
MAIL_FROM=noreply@yourdomain.com

CORS_ALLOWED_ORIGINS=https://admin.yourdomain.com,https://yourdomain.com

STORE_NAME=IT Solutions Store
PORT=8080

# PayPal return/cancel URLs (must match your customer storefront origin)
PAYPAL_RETURN_URL=http://localhost:3001/checkout/success
PAYPAL_CANCEL_URL=http://localhost:3001/checkout/cancelled

# --- apps/ui-admin ---
# API_URL is server-only (not prefixed NEXT_PUBLIC_) — used by the BFF proxy route handlers
API_URL=http://localhost:8080
NEXT_PUBLIC_CUSTOMER_URL=http://localhost:3001
NEXT_PUBLIC_PAYPAL_MODE=sandbox

# --- apps/ui-customer ---
NEXT_PUBLIC_API_URL=http://localhost:8080
# Auth.js v5 — Google OAuth (generate secret: openssl rand -base64 32)
AUTH_SECRET=replace-with-a-random-32-char-secret
AUTH_GOOGLE_ID=your-google-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-google-client-secret
